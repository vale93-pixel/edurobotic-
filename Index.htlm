<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDUROBOTIC XR - Immersive Learning</title>
    <style>
        /* Tema Cyberpunk Base */
        :root {
            --neon-cyan: #00f3ff;
            --neon-pink: #ff00ff;
            --bg-dark: #0a0a12;
            --panel-bg: rgba(16, 16, 28, 0.8);
        }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: var(--bg-dark);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: white;
        }

        /* Canvas per Three.js */
        #canvas {
            display: block;
            width: 100%;
            height: 100%;
        }

        /* Interfaccia HUD Sovrapposta */
        .hud-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none; /* Permette di cliccare il 3D sottostante */
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 20px;
            box-sizing: border-box;
        }

        .hud-overlay * {
            pointer-events: auto; /* Riabilita il click per gli elementi UI */
        }

        /* Pannello Info Oggetto (Top Left) */
        #object-info {
            background: var(--panel-bg);
            border-left: 4px solid var(--neon-cyan);
            padding: 15px;
            max-width: 300px;
            backdrop-filter: blur(10px);
            text-shadow: 0 0 5px var(--neon-cyan);
        }

        /* Statistiche (Top Right) */
        .stats-panel {
            align-self: flex-end;
            background: var(--panel-bg);
            padding: 10px 20px;
            border-bottom: 2px solid var(--neon-pink);
            display: flex;
            gap: 20px;
        }

        /* Selettore Modalità (Bottom Center) */
        .mode-selector {
            align-self: center;
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .mode-btn {
            background: transparent;
            border: 1px solid var(--neon-cyan);
            color: var(--neon-cyan);
            padding: 10px 20px;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .mode-btn:hover, .mode-btn.active {
            background: var(--neon-cyan);
            color: var(--bg-dark);
            box-shadow: 0 0 15px var(--neon-cyan);
        }

        /* Notifiche Toast */
        #toast-container {
            position: absolute;
            bottom: 100px;
            right: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .toast {
            background: rgba(0, 243, 255, 0.2);
            border: 1px solid var(--neon-cyan);
            padding: 10px 20px;
            animation: slideIn 0.3s ease-out;
        }

        /* Sottotitoli Live AI */
        #live-captions {
            align-self: center;
            background: rgba(0, 0, 0, 0.7);
            padding: 10px 30px;
            border-radius: 20px;
            font-size: 1.2em;
            display: none;
            max-width: 80%;
            text-align: center;
        }

        /* Errore XR */
        #xr-unsupported {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: var(--panel-bg);
            padding: 30px;
            text-align: center;
            border: 2px solid red;
            display: none;
        }

        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        @keyframes fadeOut {
            from { opacity: 1; }
            to { opacity: 0; }
        }
    </style>
</head>
<body>
    <canvas id="canvas"></canvas>

    <div class="hud-overlay">
        <div style="display: flex; justify-content: space-between;">
            <div id="object-info">
                Seleziona un oggetto scientifico per iniziare...
            </div>

            <div class="stats-panel">
                <div>XP: <span id="xp-count">0</span></div>
                <div>OGGETTI: <span id="objects-found">0</span>/5</div>
            </div>
        </div>

        <div id="live-captions"></div>

        <div class="mode-selector">
            <button class="mode-btn active" data-mode="desktop">Desktop</button>
            <button class="mode-btn" data-mode="vr">Visore VR</button>
            <button class="mode-btn" data-mode="ar">Realtà AR</button>
        </div>
    </div>

    <div id="toast-container"></div>

    <div id="xr-unsupported">
        <h2>WebXR non supportato</h2>
        <p>Il tuo browser o dispositivo non supporta le funzionalità VR/AR.</p>
    </div>

    <script type="module" src="./main.ts"></script>
</body>
</html>
