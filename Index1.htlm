<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edurobotic AI - Progetto Sicuro AR</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Exo+2:wght@300;400;600&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tone/14.8.49/Tone.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/webxr/ARButton.js"></script>

    <style>
        :root { --cyan: #00d4ff; --gold: #f0a500; --green: #00ff88; --bg: #0a0e1a; --panel: rgba(10,20,40,0.92); --border: rgba(0,212,255,0.3); }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg); font-family: 'Exo 2', sans-serif; color: white; overflow: hidden; }
        
        /* Cursore Oro */
        html, body { cursor: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="%23FFD700" stroke="%23000000" stroke-width="1" d="M7 2l12 12.5L13 16l3 6-2.5 1-3-6-4.5 4V2z"/></svg>'), auto !important; }

        #intro-screen { position: fixed; inset: 0; background: radial-gradient(ellipse at 50% 40%, rgba(0, 18, 51, 0.6) 0%, rgba(0, 10, 26, 0.8) 60%, rgba(0, 0, 5, 0.95) 100%); backdrop-filter: blur(6px); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 200; transition: opacity 1.5s; }
        .glass-card { background: rgba(0,212,255,0.08); backdrop-filter: blur(20px); padding: 40px; border-radius: 24px; border: 1px solid var(--border); text-align: center; max-width: 500px; width: 90%; }
        .hud-input { background: rgba(0,0,0,0.6); border: 1px solid var(--border); border-radius: 10px; padding: 15px; color: white; width: 100%; text-align: center; margin: 20px 0; outline: none; }
        .start-btn { background: linear-gradient(135deg, var(--gold), #ff8c00); color: #000; font-family: 'Orbitron', sans-serif; font-weight: 700; padding: 15px; border: none; border-radius: 10px; cursor: pointer; width: 100%; }

        #ui-layer { display: none; position: absolute; inset: 0; pointer-events: none; }
        #hud-top { position: absolute; top: 20px; left: 20px; right: 20px; display: flex; justify-content: space-between; pointer-events: auto; }
        .hud-panel { background: var(--panel); border: 1px solid var(--border); border-radius: 12px; padding: 10px 20px; }
        
        #ai-panel { position: absolute; bottom: 80px; right: 24px; width: min(380px, calc(100vw - 48px)); background: var(--panel); border: 1px solid var(--border); border-radius: 18px; display: none; pointer-events: auto; }
        .ai-body { padding: 20px; max-height: 250px; overflow-y: auto; font-size: 0.9em; line-height: 1.6; }
        #ai-question { width: 100%; padding: 10px; background: rgba(0,0,0,0.3); border: 1px solid var(--border); color: white; border-radius: 8px; margin: 10px 0; }
        
        #controls { position: absolute; bottom: 30px; left: 30px; display: grid; grid-template-areas: ". up ." "left . right" ". down ."; gap: 10px; pointer-events: auto; }
        .m-btn { width: 50px; height: 50px; background: rgba(0,30,60,0.7); border: 1px solid var(--border); color: white; border-radius: 10px; cursor: pointer; }
    </style>
</head>
<body>

<div id="intro-screen">
    <div class="glass-card">
        <h1 style="font-family:'Orbitron'; color:var(--cyan); margin-bottom:10px;">EDUROBOTIC AI</h1>
        <p>Progetto Sicuro con Backend</p>
        <input type="text" id="p-name" class="hud-input" placeholder="Tuo Nome...">
        <button class="start-btn" onclick="startApp()">ENTRA NELL'AULA</button>
    </div>
</div>

<div id="ui-layer">
    <div id="hud-top">
        <div class="hud-panel">Nome: <span id="welcome-msg" style="color:var(--gold)">—</span></div>
        <div class="hud-panel">Oggetti: <span id="found-count" style="color:var(--green)">0</span> / 10</div>
    </div>

    <div id="controls">
        <button class="m-btn" style="grid-area:up" onmousedown="mv('F')" onmouseup="st()">▲</button>
        <button class="m-btn" style="grid-area:left" onmousedown="mv('L')" onmouseup="st()">◀</button>
        <button class="m-btn" style="grid-area:right" onmousedown="mv('R')" onmouseup="st()">▶</button>
        <button class="m-btn" style="grid-area:down" onmousedown="mv('B')" onmouseup="st()">▼</button>
    </div>

    <div id="ai-panel">
        <div style="padding:15px; border-bottom:1px solid var(--border); font-weight:bold; color:var(--cyan);">PROF. GEMINI</div>
        <div class="ai-body" id="ai-conversation"></div>
        <div style="padding:15px;">
            <input type="text" id="ai-question" placeholder="Fai una domanda...">
            <button class="start-btn" onclick="askAI()" style="padding:8px; font-size:0.8em;">CHIEDI</button>
        </div>
    </div>
</div>

<div id="canvas-container"></div>

<script>
let PLAYER_NAME = "Esploratore";
let isGameStarted = false;
let dir = null;

// Configurazione scena 3D
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x0a0e1a);
const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
camera.position.set(0, 5, 12);

const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.xr.enabled = true;
document.getElementById('canvas-container').appendChild(renderer.domElement);

// Bottone AR con DOM Overlay
document.body.appendChild(THREE.ARButton.createButton(renderer, { 
    optionalFeatures: ['dom-overlay'], 
    domOverlay: { root: document.getElementById('ui-layer') } 
}));

// Luci e Griglia
scene.add(new THREE.AmbientLight(0xffffff, 0.5));
scene.add(new THREE.GridHelper(30, 15, 0x00d4ff, 0x002244));

// Il Robot
const robot = new THREE.Group();
const body = new THREE.Mesh(new THREE.CylinderGeometry(0.5, 0.7, 1.2, 8), new THREE.MeshStandardMaterial({ color: 0x9ab0cc }));
body.position.y = 0.6;
const head = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.6, 0.6), new THREE.MeshStandardMaterial({ color: 0x9ab0cc }));
head.position.y = 1.6;
robot.add(body, head);
scene.add(robot);

// Oggetti (Dalla versione Index0.html)
const library = [
    { t: "Mela di Newton", emoji: "🍎" }, { t: "DNA", emoji: "🧬" }, { t: "Atomo di Bohr", emoji: "⚛️" },
    { t: "Libro Quantistico", emoji: "📗" }, { t: "Pianeta Terra", emoji: "🌍" }, { t: "Microscopio", emoji: "🔬" },
    { t: "Sonda Spaziale", emoji: "🛸" }, { t: "Batteria AI", emoji: "🔋" }, { t: "Gatto di Schrödinger", emoji: "🐱" }, { t: "Chip Quantistico", emoji: "💡" }
];
const objects3D = [];
library.forEach((item, i) => {
    const sprite = new THREE.Sprite(new THREE.SpriteMaterial({ 
        map: new THREE.CanvasTexture((function(){
            const c = document.createElement('canvas'); c.width=64; c.height=64;
            const x = c.getContext('2d'); x.font="40px serif"; x.textAlign="center"; x.textBaseline="middle";
            x.fillText(item.emoji, 32, 32); return c;
        })())
    }));
    sprite.position.set((Math.random()-0.5)*20, 1, (Math.random()-0.5)*20);
    sprite.scale.set(1.5, 1.5, 1);
    sprite.userData = { ...item, active: true };
    scene.add(sprite);
    objects3D.push(sprite);
});

// Start App
function startApp() {
    PLAYER_NAME = document.getElementById('p-name').value || "Esploratore";
    document.getElementById('intro-screen').style.opacity = '0';
    setTimeout(() => {
        document.getElementById('intro-screen').style.display = 'none';
        document.getElementById('ui-layer').style.display = 'block';
        document.getElementById('welcome-msg').innerText = PLAYER_NAME;
        isGameStarted = true;
        speak("Sistemi attivi. Benvenuto Commander " + PLAYER_NAME + ". Sono Edurobotic.");
    }, 1500);
}

// Logica AI (Backend)
async function sendToAI(msg) {
    const conv = document.getElementById('ai-conversation');
    const url = "/.netlify/functions/ask"; // Chiama la Netlify Function

    try {
        const res = await fetch(url, {
            method: "POST",
            body: JSON.stringify({
                systemInstruction: { parts: [{ text: "Sei Edurobotic. Spiega l'oggetto senza markdown o elenchi. Sii conciso e robotico." }] },
                contents: [{ role: "user", parts: [{ text: msg }] }]
            })
        });
        const data = await res.json();
        const reply = data.candidates[0].content.parts[0].text;
        conv.innerHTML += `<div style="margin-bottom:10px; color:var(--gold);"><b>AI:</b> ${reply}</div>`;
        conv.scrollTop = conv.scrollHeight;
        speak(reply);
    } catch (e) {
        conv.innerHTML += `<div style="color:red;">Errore di connessione.</div>`;
    }
}

function speak(txt) {
    window.speechSynthesis.cancel();
    const v = new SpeechSynthesisUtterance(txt.replace(/[*_#]/g, ''));
    v.lang = 'it-IT'; v.pitch = 0.5; v.rate = 0.9; // Voce profonda e robotica
    window.speechSynthesis.speak(v);
}

function askAI() {
    const q = document.getElementById('ai-question').value;
    if(!q) return;
    document.getElementById('ai-conversation').innerHTML += `<div><b>Tu:</b> ${q}</div>`;
    sendToAI(q);
    document.getElementById('ai-question').value = '';
}

// Loop Animazione
function mv(d) { dir = d; } function st() { dir = null; }
function animate() {
    if (isGameStarted) {
        if(dir === 'F') robot.position.z -= 0.1; if(dir === 'B') robot.position.z += 0.1;
        if(dir === 'L') robot.position.x -= 0.1; if(dir === 'R') robot.position.x += 0.1;
        camera.position.lerp(new THREE.Vector3(robot.position.x, 5, robot.position.z + 8), 0.05);
        camera.lookAt(robot.position);

        objects3D.forEach(obj => {
            if (obj.userData.active && robot.position.distanceTo(obj.position) < 1.5) {
                obj.userData.active = false; obj.visible = false;
                document.getElementById('found-count').innerText = ++countFound;
                document.getElementById('ai-panel').style.display = 'block';
                sendToAI("Parlami dell'oggetto " + obj.userData.t);
            }
        });
    }
    renderer.render(scene, camera);
}
renderer.setAnimationLoop(animate);
</script>
</body>
</html>
